project_name: ML_project
course: ML: Learning, Adaptation, and Uncertainty 2026
phase: planning_and_documentation

hard_constraints:
  - no_code_implementation_in_this_phase
  - focus_on_classifier_listing_and_algorithm_preparation
  - compare_weak_vs_strong_classifiers_in_learnplusplus

confirmed_decisions:
  classifier_selection_criteria:
    - predictive_quality
    - compute_cost
  roadmap_split:
    - phase_1_classifier_selection_and_learnplusplus_design
    - phase_2_medical_image_recognition_implementation
    - phase_3_general_vision_expansion
  phase_3_subsplit:
    - phase_3a_photo_and_drone_image_recognition
    - phase_3b_area_mapping_and_geospatial_outputs
    - phase_3c_swarm_control_integration
  data_strategy:
    - use_public_benchmark_data
    - use_medical_imaging_data
  medical_priority_order:
    - nifti
    - bids
  presentation_scope:
    - classifier_presentation_only_in_markdown_docs

proposed_output_subfolder: output/output_gpt-5.3-codex

required_files:
  - architecture.md
  - SKILLS.md
  - .context

candidate_weak_classifiers:
  - decision_tree_depth_1_to_3
  - gaussian_naive_bayes
  - logistic_regression_regularized
  - linear_svm_or_sgd_hinge
  - lda
  - small_mlp

candidate_strong_classifiers:
  - random_forest
  - rbf_svm
  - gradient_boosting_family
  - medium_mlp
  - feature_encoder_plus_linear_head

evaluation_principle:
  - rank_by_quality_plus_cost_weighted_score
  - report_per_batch_and_cumulative_results

open_items_to_finalize:
  - exact_public_benchmark_dataset_name
  - exact_medical_dataset_name_or_source
  - class_labels_and_task_definition_for_first_experiment
  - target_compute_budget_per_experiment

next_actions_no_code:
  - choose_one_public_dataset_and_one_medical_dataset
  - lock_shortlist_of_3_weak_and_3_strong_models
  - define_batching_plan_D1_to_Dk
  - prepare_experiment_scorecard_template

project_roadmap_status:
  phase_1:
    name: classifier_selection_and_learnplusplus_design
    status: active
    output_focus: documentation_and_handoff
  phase_2:
    name: medical_image_recognition_implementation
    status: planned
    starts_after: phase_1_exit_gate
  phase_3:
    name: general_image_and_drone_expansion
    status: planned
    starts_after: phase_2_exit_gate
    subphases:
      - phase_3a_photo_and_drone_image_recognition
      - phase_3b_area_mapping_and_geospatial_outputs
      - phase_3c_swarm_control_integration